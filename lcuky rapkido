-- ╚══════════════════════════╝

local currentTab = 0  -- nenhuma aba ativa ainda

local function selectTab(index)
    if currentTab == index then return end
    currentTab = index

    for i = 1, #TAB_NAMES do
        local isActive = (i == index)

        -- texto e cor do botão
        tabBtns[i].TextColor3 = isActive
            and Color3.fromRGB(17, 17, 17)
            or  Color3.fromRGB(180, 180, 180)
        tabBtns[i].Font = isActive
            and Enum.Font.GothamSemibold
            or  Enum.Font.Gotham

        -- underline animado
        TweenService:Create(tabUnderlines[i], TweenInfo.new(0.15), {
            Size = isActive
                and UDim2.new(0, TAB_WIDTH * 0.6, 0, 2)
                or  UDim2.new(0, 0, 0, 2)
        }):Play()

        -- mostrar/esconder página
        tabPages[i].Visible = isActive
    end
end

-- conecta clique em cada aba
for i = 1, #TAB_NAMES do
    local idx = i  -- captura local do índice (evita closure bug do Lua)
    tabBtns[i].MouseButton1Click:Connect(function()
        selectTab(idx)
    end)
end

