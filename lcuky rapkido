local function makeSection(parent, text, yOff)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -32, 0, 16)
    lbl.Position = UDim2.new(0, 16, 0, yOff)
    lbl.BackgroundTransparency = 1
    lbl.Text = string.upper(text)
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 10
    lbl.TextColor3 = Color3.fromRGB(190, 190, 190)
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = parent
end

local function makeRow(parent, yOff, name, desc)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, -32, 0, 52)
    row.Position = UDim2.new(0, 16, 0, yOff)
    row.BackgroundColor3 = Color3.fromRGB(250, 250, 250)
    row.BorderSizePixel = 0
    row.Parent = parent
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 10)

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(230, 230, 230)
    stroke.Thickness = 1
    stroke.Parent = row

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -60, 0, 18)
    lbl.Position = UDim2.new(0, 12, 0, 8)
    lbl.BackgroundTransparency = 1
    lbl.Text = name
    lbl.Font = Enum.Font.GothamSemibold
    lbl.TextSize = 13
    lbl.TextColor3 = Color3.fromRGB(17, 17, 17)
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = row

    local sub = Instance.new("TextLabel")
    sub.Size = UDim2.new(1, -60, 0, 14)
    sub.Position = UDim2.new(0, 12, 0, 28)
    sub.BackgroundTransparency = 1
    sub.Text = desc
    sub.Font = Enum.Font.Gotham
    sub.TextSize = 11
    sub.TextColor3 = Color3.fromRGB(170, 170, 170)
    sub.TextXAlignment = Enum.TextXAlignment.Left
    sub.Parent = row

    return row
end

local function makeToggle(row)
    -- trilho
    local track = Instance.new("Frame")
    track.Size = UDim2.new(0, 38, 0, 22)
    track.Position = UDim2.new(1, -50, 0.5, -11)
    track.BackgroundColor3 = Color3.fromRGB(220, 220, 220)
    track.BorderSizePixel = 0
    track.Parent = row
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    -- bolinha
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = UDim2.new(0, 3, 0.5, -8)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BorderSizePixel = 0
    knob.ZIndex = track.ZIndex + 1
    knob.Parent = track
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    -- área clicável em cima do trilho
    local hitbox = Instance.new("TextButton")
    hitbox.Size = UDim2.new(1, 0, 1, 0)
    hitbox.BackgroundTransparency = 1
    hitbox.Text = ""
    hitbox.ZIndex = track.ZIndex + 2
    hitbox.Parent = track

    local state = false

    local function setState(on)
        state = on
        local col = on and Color3.fromRGB(17, 17, 17) or Color3.fromRGB(220, 220, 220)
        local pos = on and UDim2.new(0, 19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
        TweenService:Create(track, TweenInfo.new(0.18), {BackgroundColor3 = col}):Play()
        TweenService:Create(knob, TweenInfo.new(0.18), {Position = pos}):Play()
    end

    return hitbox, setState, function() return state end
end

local function makeStatus(parent, yOff)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -32, 0, 16)
    lbl.Position = UDim2.new(0, 16, 0, yOff)
    lbl.BackgroundTransparency = 1
