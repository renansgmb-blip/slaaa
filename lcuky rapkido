local p1 = tabPages[1]
makeSection(p1, "Recompensas", 14)
local rowReward = makeRow(p1, 36, "Auto Coletar Recompensas", "50 threads · ClaimReward RF")
local hitReward, setReward, getReward = makeToggle(rowReward)
local statusReward = makeStatus(p1, 96)

hitReward.MouseButton1Click:Connect(function()
    local on = not getReward()
    setReward(on)
    running = on

    if on then
        statusReward.Text = "● Coletando em 50 threads..."
        statusReward.TextColor3 = Color3.fromRGB(80, 180, 80)

        local ok, claim = pcall(function()
            return ReplicatedStorage
                :WaitForChild("Packages")
                :WaitForChild("_Index")
                :WaitForChild("sleitnick_knit@1.7.0")
                :WaitForChild("knit")
                :WaitForChild("Services")
                :WaitForChild("ChallengeService")
                :WaitForChild("RF")
                :WaitForChild("ClaimReward")
        end)

        if ok then
            for t = 1, 50 do
                task.spawn(function()
                    local localId = rewardId + (t * 10000)
                    while running do
                        claim:InvokeServer(localId)
                        localId += 10000
                    end
                end)
            end
        else
            statusReward.Text = "● Erro: ClaimReward não encontrado"
            statusReward.TextColor3 = Color3.fromRGB(220, 60, 60)
            setReward(false)
            running = false
        end
    else
        statusReward.Text = "● Inativo"
        statusReward.TextColor3 = Color3.fromRGB(190, 190, 190)
    end
end)

